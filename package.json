{
  "name": "mailclient",
  "version": "0.0.1",
  "description": "Schlanker, lokaler Mail-Workflow-Client fuer Windows 11 mit Multi-Account-Support fuer Microsoft 365 und Gmail",
  "main": "out/main/index.js",
  "author": "Kurt Soeser",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\""
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/luxon": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@radix-ui/react-slot": "^1.1.0",
    "@tiptap/extension-color": "^3.23.2",
    "@tiptap/extension-highlight": "^3.23.2",
    "@tiptap/extension-image": "^3.23.2",
    "@tiptap/extension-link": "^3.23.2",
    "@tiptap/extension-placeholder": "^3.23.2",
    "@tiptap/extension-table": "^3.23.2",
    "@tiptap/extension-table-cell": "^3.23.2",
    "@tiptap/extension-table-header": "^3.23.2",
    "@tiptap/extension-table-row": "^3.23.2",
    "@tiptap/extension-text-align": "^3.23.2",
    "@tiptap/extension-text-style": "^3.23.2",
    "@tiptap/extension-underline": "^3.23.2",
    "@tiptap/pm": "^3.23.2",
    "@tiptap/react": "^3.23.2",
    "@tiptap/starter-kit": "^3.23.2",
    "@uiw/react-md-editor": "^4.1.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.2",
    "electron-updater": "^6.8.3",
    "googleapis": "^144.0.0",
    "i18next": "^26.1.0",
    "isomorphic-fetch": "^3.0.0",
    "lucide-react": "^0.460.0",
    "luxon": "^1.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.7",
    "react-virtuoso": "^4.18.7",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/luxon": "^1.27.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^3.0.5"
  }
}
