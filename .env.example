# Publisher-OAuth (optional, Praefix MAILCLIENT_)
# Kopiere nach .env und fuelle fuer Verteilungs-Builds.
# Siehe README: Abschnitt «OAuth fuer Endnutzer».

MAILCLIENT_MICROSOFT_CLIENT_ID=
MAILCLIENT_GOOGLE_CLIENT_ID=
# Optional: leer lassen fuer Google PKCE (Desktop-Client / oeffentlicher Client)
MAILCLIENT_GOOGLE_CLIENT_SECRET=

# Optional: HTTPS-JSON mit gleichen Schluesseln wie oben (Rotation ohne Neuinstaller)
# MAILCLIENT_REMOTE_OAUTH_CONFIG_URL=https://example.com/mailclient-oauth.json

# Optional: Links im Ersteinrichtungs-Assistenten
# MAILCLIENT_PRIVACY_URL=https://example.com/datenschutz
# MAILCLIENT_HELP_URL=https://example.com/hilfe
